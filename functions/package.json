{
  "name": "spezi-firebase-template-functions",
  "version": "1.0.0",
  "description": "Firebase Functions for Spezi Template",
  "main": "lib/index.js",
  "type": "module",
  "dependencies": {
    "@stanfordspezi/spezi-firebase-cloud-messaging": "^0.1.5",
    "@stanfordspezi/spezi-firebase-fhir": "^0.1.5",
    "@stanfordspezi/spezi-firebase-utils": "^0.1.5",
    "@types/fhir": "^0.0.41",
    "fhir": "^4.11.1",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.5.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "typescript": "^5.2.2",
    "vitest": "^3.0.0"
  },
  "private": true,
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "serve:seeded": "npm run build && node serve-seeded.mjs",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf lib",
    "test": "vitest run",
    "test:emulators": "vitest run"
  },
  "engines": {
    "node": "22"
  }
}
