{
  "name": "spezi-firebase-template-functions",
  "version": "1.0.0",
  "description": "Firebase Functions for Spezi Template",
  "main": "lib/index.js",
  "dependencies": {
    "@stanfordbdhg/spezi-firebase-models": "file:models",
    "@stanfordspezi/spezi-firebase-cloud-messaging": "^0.1.5",
    "@stanfordspezi/spezi-firebase-fhir": "^0.1.5",
    "@stanfordspezi/spezi-firebase-utils": "^0.1.5",
    "@types/fhir": "^0.0.41",
    "fhir": "^4.11.1",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.5.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint": "^8.54.0",
    "globals": "^16.3.0",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.38.0"
  },
  "private": true,
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "serve:seeded": "npm run build && firebase emulators:start --import=./emulator-data --export-on-exit=./emulator-data",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rm -rf lib",
    "test": "echo \"No tests specified\" && exit 0",
    "test:emulators": "echo \"No emulator tests specified\" && exit 0"
  },
  "engines": {
    "node": "22"
  }
}
