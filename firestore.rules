rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read and write their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Users can read and write their own subcollections
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Organizations are readable by authenticated users
    match /organizations/{organizationId} {
      allow read: if request.auth != null;
    }
    
    // Questionnaires are readable by authenticated users
    match /questionnaires/{questionnaireId} {
      allow read: if request.auth != null;
    }
    
    // Allow clinicians and owners to read patient data
    match /users/{userId} {
      allow read: if request.auth != null && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.type in ['clinician', 'owner']);
      
      match /{document=**} {
        allow read: if request.auth != null && 
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.type in ['clinician', 'owner']);
      }
    }
  }
}